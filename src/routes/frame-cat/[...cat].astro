---
export const prerender = false;

const catParam = decodeURIComponent(Astro.params.cat || '');
const origin = Astro.url.origin;

const overrideLayout = Astro.url.searchParams.get('overrideLayout') || '';
const overridePropsRaw = Astro.url.searchParams.get('overrideProps') || '';
let overrideProps: Record<string, any> = {};
if (overridePropsRaw) {
  try { overrideProps = JSON.parse(decodeURIComponent(overridePropsRaw)); } catch { }
}

let catComps: Array<{ slug: string; name: string; path?: string }> = [];
try {
  const res = await fetch(`${origin}/__stargazer/render-category-meta/${encodeURIComponent(catParam)}`);
  if (res.ok) catComps = await res.json();
} catch { }

let darkModeConfig: any = {};
try {
  const regRes = await fetch(`${origin}/__stargazer/registry.json`);
  if (regRes.ok) {
    const reg = await regRes.json();
    if (reg.config?.darkMode && typeof reg.config.darkMode === 'object') {
      darkModeConfig = reg.config.darkMode;
    }
  }
} catch { }

const componentItems: Array<{ slug: string; name: string; filename: string; Component: any; props: any }> = [];
let Layout: any = null;
let cssLinks: string[] = [];

for (const comp of catComps) {
  try {
    const pathsUrl = overrideLayout
      ? `${origin}/__stargazer/paths/${comp.slug}?overrideLayout=${encodeURIComponent(overrideLayout)}`
      : `${origin}/__stargazer/paths/${comp.slug}`;

    const [pathsData, previewData] = await Promise.all([
      fetch(pathsUrl).then(r => r.json()),
      fetch(`${origin}/__stargazer/preview/${comp.slug}`).then(r => r.json()),
    ]);

    if (!Layout && pathsData.layoutFsUrl) {
      Layout = (await import(/* @vite-ignore */ pathsData.layoutFsUrl)).default;
    }
    for (const url of (pathsData.cssLinks || [])) {
      if (!cssLinks.includes(url)) cssLinks.push(url);
    }

    const Component = (await import(/* @vite-ignore */ pathsData.compFsUrl)).default;
    const props = { ...(previewData.props || {}), ...overrideProps };
    const filename = comp.path ? comp.path.split('/').pop() || comp.name : comp.name;
    componentItems.push({ slug: comp.slug, name: comp.name, filename, Component, props });
  } catch { }
}

const darkModeConfigStr = JSON.stringify(darkModeConfig);
---

{Layout ? (
  <Layout>
    {cssLinks.map(url => <link rel="stylesheet" href={url} />)}

    {componentItems.map(({ slug, name, filename, Component, props }, i) => (
      <div class="sg-section" data-slug={slug}>
        <div class="sg-label">
          <span class="sg-label__dot"></span>
          {name}
          <button class="sg-label__copy" data-copy={filename} onclick="sgCatCopy(this)" title={`Copy: ${filename}`}>
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 4H6C4.89543 4 4 4.89543 4 6V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V6C20 4.89543 19.1046 4 18 4H16M8 4C8 5.10457 8.89543 6 10 6H14C15.1046 6 16 5.10457 16 4M8 4C8 2.89543 8.89543 2 10 2H14C15.1046 2 16 2.89543 16 4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
        <Component {...props} />
        {i < componentItems.length - 1 && <div class="sg-divider" />}
      </div>
    ))}

    <script is:inline define:vars={{ darkModeConfigStr }}>
      window.__stargazerDarkMode = JSON.parse(darkModeConfigStr);
    </script>
    <script is:inline src="/__stargazer_controls.js"></script>
    <script is:inline>
      function sgCatCopy(btn) {
        var text = btn.getAttribute('data-copy');
        if (!text) return;
        var path = btn.querySelector('path');
        navigator.clipboard.writeText(text).then(function() {
          btn.classList.add('sg-cat-copied');
          if (path) path.setAttribute('d', 'M20 6L9 17L4 12');
          setTimeout(function() {
            btn.classList.remove('sg-cat-copied');
            if (path) path.setAttribute('d', 'M8 4H6C4.89543 4 4 4.89543 4 6V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V6C20 4.89543 19.1046 4 18 4H16M8 4C8 5.10457 8.89543 6 10 6H14C15.1046 6 16 5.10457 16 4M8 4C8 2.89543 8.89543 2 10 2H14C15.1046 2 16 2.89543 16 4');
          }, 2000);
        });
      }
    </script>
    <script>
      function sgReportHeight() {
        var h = Math.max(document.documentElement.scrollHeight, document.body.scrollHeight);
        parent.postMessage({ type: 'sg-resize', height: h }, '*');
      }
      window.addEventListener('load', function() {
        sgReportHeight();
        setTimeout(sgReportHeight, 800);
        setTimeout(sgReportHeight, 2000);
      });
    </script>
  </Layout>
) : (
  <>
    {cssLinks.map(url => <link rel="stylesheet" href={url} />)}
    {componentItems.map(({ slug, name, Component, props }) => (
      <div class="sg-section" data-slug={slug}>
        <div class="sg-label">{name}</div>
        <Component {...props} />
      </div>
    ))}
  </>
)}

<style>
  :root {
    --sg-label-bg: rgba(8, 8, 26, 0.92);
    --sg-label-text: rgba(221, 241, 96, 0.95);
    --sg-label-border-right: rgba(221, 241, 96, 0.2);
    --sg-label-border-bottom: rgba(221, 241, 96, 0.12);
    --sg-label-dot: rgba(221, 241, 96, 0.8);
    --sg-divider-start: rgba(221, 241, 96, 0.35);
    --sg-divider-mid: rgba(221, 241, 96, 0.08);
  }
  html[data-theme="light"] {
    --sg-label-bg: rgba(255, 255, 255, 0.92);
    --sg-label-text: #8a9600;
    --sg-label-border-right: rgba(0, 0, 0, 0.1);
    --sg-label-border-bottom: rgba(0, 0, 0, 0.06);
    --sg-label-dot: #8a9600;
    --sg-divider-start: rgba(0, 0, 0, 0.15);
    --sg-divider-mid: rgba(0, 0, 0, 0.05);
  }

  .sg-section {
    position: relative;
    width: 100%;
  }

  .sg-label {
    position: sticky;
    top: 0;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--sg-label-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 8px 18px 8px 14px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 18px;
    font-weight: 500;
    color: var(--sg-label-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-right: 1px solid var(--sg-label-border-right);
    border-bottom: 1px solid var(--sg-label-border-bottom);
    user-select: none;
  }

  .sg-label__copy {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    background: transparent;
    border: none;
    border-left: 1px solid rgba(221, 241, 96, 0.12);
    cursor: pointer;
    color: rgba(221, 241, 96, 0.25);
    padding: 2px 4px 2px 10px;
    border-radius: 0;
    transition: color 0.2s;
    margin-left: 6px;
  }
  .sg-label__copy:hover {
    color: rgba(221, 241, 96, 0.9);
  }
  .sg-label__copy.sg-cat-copied { color: rgba(221, 241, 96, 0.9); }
  .sg-label__copy svg { width: 13px; height: 13px; display: block; flex-shrink: 0; }
  .sg-label__copy svg path { stroke: currentColor; fill: none; }

  .sg-label__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sg-label-dot);
    flex-shrink: 0;
  }

  .sg-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      var(--sg-divider-start) 0%,
      var(--sg-divider-mid) 60%,
      transparent 100%
    );
  }
</style>
