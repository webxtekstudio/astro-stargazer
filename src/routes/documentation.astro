              >Global props applied to all components</td
            ></tr
          >
          <tr
            ><td><code>defaultLayout</code></td><td><code>string</code></td><td
              ><code>undefined</code></td
            ><td>Key from <code>layouts</code> map to use by default</td></tr
          >
          <tr
            ><td><code>layoutMap</code></td><td
              ><code>Record&lt;string, string&gt;</code></td
            ><td><code>undefined</code></td><td
              >Map directory paths to layout keys (auto/files mode)</td
            ></tr
          >
          <tr
            ><td><code>layouts</code></td><td
              ><code>Record&lt;string, string&gt;</code></td
            ><td><code>{"{}"}</code></td><td
              >Map of layout names to file paths</td
            ></tr
          >
          <tr
            ><td><code>components</code></td><td
              ><code>StargazerComponent[]</code></td
            ><td><code>[]</code></td><td
              >Components to preview (files mode only)</td
            ></tr
          >
          <tr
            ><td><code>scanDir</code></td><td><code>string</code></td><td
              ><code>'./src/components'</code></td
            ><td>Directory to scan (files mode only)</td></tr
          >
          <tr
            ><td><code>base</code></td><td><code>string</code></td><td
              ><code>'/stargazer'</code></td
            ><td>URL path for Stargazer</td></tr
          >
