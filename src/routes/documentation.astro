            ><td><code>buildable</code></td><td><code>boolean</code></td><td
              ><code>false</code></td
            ><td>Include in production builds (default: dev-only)</td></tr
          >
          <tr
            ><td><code>darkMode</code></td><td
              ><code>false &#124; DarkModeConfig</code></td
            ><td><code>{"{}"}</code> (enabled)</td><td
