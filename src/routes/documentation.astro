          ><tr
            ><th>Option</th><th>Type</th><th>Default</th><th>Description</th
            ></tr
          ></thead
        >
        <tbody>
          <tr
            ><td><code>mode</code></td><td
              ><code>'files' &#124; 'auto'</code></td
            ><td><code>'auto'</code></td><td>How components are discovered</td
            ></tr
          >
          <tr
            ><td><code>exclude</code></td><td><code>string[]</code></td><td
              ><code>['src/layouts','src/pages','src/styles']</code></td
            ><td>Paths to exclude (auto mode only)</td></tr
          >
          <tr
            ><td><code>defaults</code></td><td
              ><code>Record&lt;string, unknown&gt;</code></td
