---
interface RegistryEntry {
    slug: string;
    name: string;
    description?: string;
    category: string;
    hasLayout: boolean;
    layoutKey?: string;
}
function layoutFileName(
    key: string | undefined,
    layoutsMap: Record<string, string>,
    defaultKey?: string,
): string {
    if (!key || !layoutsMap[key]) return "";
    if (key === defaultKey) return "Default Layout";
    const path = layoutsMap[key];
    return path.split("/").pop() || path;
}
import { WEBXTEK_URL } from '../config';
const registryUrl = new URL("/__stargazer/registry.json", Astro.url.origin);
const res = await fetch(registryUrl.href);
const data = await res.json();
const generateStars = (n: number) => {
    let value = `${Math.floor(Math.random() * 2000)}px ${Math.floor(Math.random() * 2000)}px #FFF`;
    for (let i = 1; i < n; i++) {
        value += `, ${Math.floor(Math.random() * 2000)}px ${Math.floor(Math.random() * 2000)}px #FFF`;
    }
    return value;
};
const shadowsSmall = generateStars(300);
const shadowsMedium = generateStars(70);
const shadowsBig = generateStars(30);
const components: RegistryEntry[] = data.components || [];
const basePath: string = data.config?.base || "/stargazer";
const currentMode: string = data.config?.mode || "auto";
const isAutoMode: boolean = currentMode === "auto";
const layouts: Record<string, string> = data.config?.layouts || {};
const defaultLayout: string = data.config?.defaultLayout || "";
const layoutKeys = Object.keys(layouts);
const modeTooltipTitle =
    currentMode === "auto"
        ? "Auto Mode"
        : "Files Mode";
const modeTooltipBody =
    currentMode === "auto"
        ? `Discovers all <code>.astro</code> files inside <code>src/</code> automatically. No config file required.<br><br>To exclude paths, add an <code>exclude</code> list in <code>stargazer.config.ts</code>.<br>To switch: set <code>mode: 'files'</code> and list components in your config.`
        : `Components are listed manually in <code>stargazer.config.ts</code>.<br><br>To auto-discover everything, set <code>mode: 'auto'</code> in your config.`;
const groups = new Map<string, RegistryEntry[]>();
for (const comp of components) {
    const cat = comp.category || "Uncategorized";
    if (!groups.has(cat)) groups.set(cat, []);
    groups.get(cat)!.push(comp);
}
const categories = Array.from(groups.entries());
const navLinksConfig: any[] = data.config?.navLinks || [];
const logoHref: string = data.config?.logoHref || basePath;
const layoutsJson = JSON.stringify(layouts);
const componentsJson = JSON.stringify(
    components.map((c) => ({
        slug: c.slug,
        layoutKey: c.layoutKey || "",
        name: c.name,
        category: c.category || "Uncategorized",
    })),
);
