            (function () {
                try {
                    var canvas = document.createElement("canvas");
                    canvas.width = canvas.height = 64;
                    var ctx = canvas.getContext("2d");
                    if (!ctx || typeof Path2D === "undefined") return;
                    var link = document.getElementById("sg-favicon");
                    if (!link) return;
                    var path = new Path2D(
                        "M12 3C12 7.97056 16.0294 12 21 12C16.0294 12 12 16.0294 12 21C12 16.0294 7.97056 12 3 12C5.6655 12 8.06036 10.8412 9.70832 9",
