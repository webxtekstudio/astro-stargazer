---
interface Props {
  [key: string]: any;
}
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Component Preview</title>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        /* Dark mode (default) */
        --sg-bg:          #0f0f13;
        --sg-surface:     #1a1a24;
        --sg-text:        #e4e4f0;
        --sg-text-muted:  #7a7a98;
        --sg-border:      #2a2a3a;
        --sg-font: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
                   Helvetica, Arial, sans-serif;
      }

      html[data-theme="light"] {
        --sg-bg:         #f5f5f8;
        --sg-surface:    #ffffff;
        --sg-text:       #18181f;
        --sg-text-muted: #6b6b88;
        --sg-border:     #dfdfe8;
      }

      body {
        min-height: 100vh;
        background: var(--sg-bg);
        color: var(--sg-text);
        font-family: var(--sg-font);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      /* Basic typographic defaults */
      h1, h2, h3, h4, h5, h6 { line-height: 1.2; }
      a { color: inherit; }
      img, video, svg { max-width: 100%; display: block; }
      button { font: inherit; cursor: pointer; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
