  // base: '/stargazer',

  // -- Dark Mode Toggle -------------------------------------------
  // Set to false to disable the dark/light toggle.
  darkMode: {
    method: 'attribute',        // 'attribute' | 'class' | 'data-theme'
    // attribute: 'color-scheme', // (default: 'color-scheme')
    // target: 'html',
    // dark: 'dark',
