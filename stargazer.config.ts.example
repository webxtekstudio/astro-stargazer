  // Zero-config option: switch to 'auto' and remove the components list.
  // Layouts, pages, and styles are excluded automatically.
  // Optionally exclude more paths:
  // exclude: ['src/partials'],

  // -- Global Defaults --------------------------------------------
  // Props applied to ALL components (unless overridden per component).
