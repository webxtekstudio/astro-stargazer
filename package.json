{
  "name": "astro-stargazer",
  "version": "1.5.4",
  "description": "Preview your Astro components in isolation with viewport simulation, zoom controls and dark mode toggle. Zero-config, dev-only, lightweight.",
  "type": "module",
  "main": "./dist/integration.js",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js",
      "default": "./dist/integration.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js",
      "default": "./dist/helpers.js"
    }
  },
  "bin": {
    "create-stargazer": "./bin/create-stargazer.mjs"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "bin/**/*",
    "README.md",
    "DOCUMENTATION.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "component-preview",
    "stargazer",
    "storybook-alternative",
    "dev-tools",
    "design-system",
    "ui-components",
    "viewport-simulation"
  ],
  "author": "Webxtek <jt@webxtek.com>",
  "license": "MIT",
  "homepage": "https://astro-stargazer.pages.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/webxtekagency/astro-stargazer"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "astro": ">=4.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "astro": "^6.0.8",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
